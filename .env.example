# ─────────────────────────────────────────────────────────────
# Variables de entorno del frontend (Vite)
#
# IMPORTANTE: Vite inyecta estas variables EN TIEMPO DE BUILD.
# Si cambias la URL del backend, debes volver a compilar
# (npm run build) para que el cambio surta efecto.
#
# Copia este archivo:
#   - .env                -> desarrollo local
#   - .env.production     -> build de producción
# ─────────────────────────────────────────────────────────────

# URL base de la API REST del backend (incluye /api)
# Desarrollo:  http://localhost:8000/api
# Producción:  https://TU-BACKEND.dominio.com/api
VITE_API_URL=http://localhost:8000/api

# URL base del storage público del backend (fotos de locales/productos)
# Desarrollo:  http://localhost:8000/storage
# Producción:  https://TU-BACKEND.dominio.com/storage
VITE_STORAGE_URL=http://localhost:8000/storage
